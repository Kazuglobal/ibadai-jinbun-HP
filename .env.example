# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_CHAT_MODEL: Optional. Defaults to the lowest-cost Gemini chat model.
GEMINI_CHAT_MODEL="gemini-2.5-flash-lite"

# Chat cost controls. Defaults target a monthly cap of about 1,000 JPY.
CHAT_MONTHLY_BUDGET_JPY="1000"
CHAT_USD_JPY_RATE="160"
CHAT_MAX_HISTORY_MESSAGES="8"
CHAT_RECENT_MESSAGE_RETENTION_DAYS="7"

# Vercel production storage for chat budget/analytics.
# Configure Vercel KV / Upstash Redis and set either KV_* or UPSTASH_* variables.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Required token to view /api/chat/usage, /api/chat/analytics, and /admin/chat-analytics.
# Admin dashboard uses this token through a login form and httpOnly cookie.
# API access may also use Authorization: Bearer <token>.
CHAT_ANALYTICS_TOKEN=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GAS_WEBAPP_URL: Optional Google Apps Script web application deployment URL
GAS_WEBAPP_URL=""

# Contact and address-update form webhook. The endpoint must accept JSON and
# send email to the fixed recipients supplied by the server. Falls back to
# GAS_WEBAPP_URL when omitted.
FORM_WEBHOOK_URL=""
