# GEMINI_API_KEY: Required. STORIES will not use canned or simulated interview
# questions when this is missing.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_CHAT_MODEL: Optional. Defaults to the lowest-cost Gemini chat model.
GEMINI_CHAT_MODEL="gemini-2.5-flash-lite"

# STORIES AI interview. Every question, including the first and benefit
# question, is generated by this model from the profile and prior answers.
STORIES_GEMINI_MODEL="gemini-2.5-flash-lite"

# STORIES review notifications.
# Use a webhook for text-only review notifications.
SLACK_STORIES_WEBHOOK_URL=""
# To also upload submitted photos, configure a Slack bot token and channel ID.
# The bot needs chat:write and files:write scopes and must be in the channel.
SLACK_BOT_TOKEN=""
SLACK_STORIES_CHANNEL_ID=""

# Chat cost controls. Defaults target a monthly cap of about 1,000 JPY.
CHAT_MONTHLY_BUDGET_JPY="1000"
CHAT_USD_JPY_RATE="160"
CHAT_MAX_HISTORY_MESSAGES="8"
# Long-term question/answer log (admin analytics). Each Q&A pair is kept for this many days.
CHAT_RECENT_MESSAGE_RETENTION_DAYS="365"
# Max number of Q&A pairs retained (rolling) and shown in the admin dashboard.
CHAT_RECENT_MESSAGE_LIMIT="1000"
CHAT_ANALYTICS_DISPLAY_LIMIT="100"

# Vercel production storage for chat budget/analytics.
# Configure Vercel KV / Upstash Redis and set either KV_* or UPSTASH_* variables.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Required token to view /api/chat/usage, /api/chat/analytics, and /admin/chat-analytics.
# Admin dashboard uses this token through a login form and httpOnly cookie.
# API access may also use Authorization: Bearer <token>.
CHAT_ANALYTICS_TOKEN=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GAS_WEBAPP_URL: Optional Google Apps Script web application deployment URL
GAS_WEBAPP_URL=""
